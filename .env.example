# Copy to .env for local development. Set all of these on Railway as well.

# Postgres connection string. On Railway, the Postgres plugin sets this automatically.
DATABASE_URL=postgresql://user:password@localhost:5432/gofirst

# Long random string used to sign session cookies. Rotate = logs everyone out.
SESSION_SECRET=change-me-to-a-long-random-string

# Public URL of the app. Locally, http://localhost:3000. On Railway, the service URL.
BASE_URL=http://localhost:3000

# Google OAuth 2.0 credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Port the server listens on. Railway sets this automatically; defaults to 3000 locally.
PORT=3000

# 'development' or 'production'. Controls cookie security, caching, etc.
NODE_ENV=development
